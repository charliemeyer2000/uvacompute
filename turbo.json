{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["BETTER_AUTH_SECRET", "BETTER_AUTH_URL"],
      "inputs": [".env"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["BETTER_AUTH_SECRET", "BETTER_AUTH_URL"],
      "inputs": [".env"]
    },
    "test:watch": {
      "persistent": true,
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}

{
  "name": "cli",
  "version": "0.0.47",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "build": "bun build index.ts --target=node --outdir ./dist",
    "build:prod": "bun build --target=node --define process.env.NODE_ENV='\"production\"' index.ts --outdir ./dist",
    "build-binary": "bun build --compile ./index.ts --outfile ./dist/uvacompute",
    "build-binary:prod": "bun build --compile --define process.env.NODE_ENV='\"production\"' ./index.ts --outfile ./dist/uvacompute",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/commander": "^2.12.5",
    "@types/js-yaml": "^4.0.9",
    "@types/tabtab": "^3.0.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.0",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "js-yaml": "^4.1.1",
    "open": "^10.1.0",
    "ora": "^8.2.0",
    "tabtab": "^3.0.2",
    "zod": "^4.1.5"
  }
}

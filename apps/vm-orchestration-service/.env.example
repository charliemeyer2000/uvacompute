# Environment (development or production)
ENV=development

# Site URL for callbacks
SITE_BASE_URL=http://localhost:3000

# Shared secret for authenticating requests from the site
ORCHESTRATION_SHARED_SECRET=

# FRP (fast reverse proxy) configuration
FRP_SERVER_ADDR=
FRP_SERVER_PORT=7000
FRP_AUTH_TOKEN=

# Cloudflare (optional, for endpoint DNS management)
CLOUDFLARE_API_TOKEN=

# Kubernetes (optional, defaults to in-cluster config)
KUBECONFIG=
KUBEVIRT_NAMESPACE=uvacompute

# VM image sources (optional, defaults to Ubuntu cloud image)
VM_IMAGE_SOURCE_URL=
VM_IMAGE_GPU_SOURCE_URL=
VM_STORAGE_CLASS=local-path
VM_STORAGE_ACCESS_MODE=ReadWriteOnce
GOLDEN_IMAGE_SIZE_GB=4
